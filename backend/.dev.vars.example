# Copy to `.dev.vars` for `wrangler dev` (never commit `.dev.vars`).
# MySQL is provided via Hyperdrive in wrangler.toml — these are optional locally
# when USE_HYPERDRIVE=1, but set them if you run the worker against Hyperdrive
# without a local tunnel.

USE_HYPERDRIVE=1
NODE_ENV=development

STUDENT_AUTH_SECRET=dev-only-change-me
SUPABASE_URL=https://okeiftbrwhfehflpxogs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# AUTHORIZE_API_LOGIN_ID=
# AUTHORIZE_TRANSACTION_KEY=
# OPENAI_API_KEY=
