# --- MySQL (local example) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_LOCAL_PASSWORD
DB_NAME=school

# --- MySQL (AWS RDS example — copy to Render + use your RDS endpoint & admin password) ---
# DB_HOST=your-db.xxxxx.us-east-2.rds.amazonaws.com
# DB_PORT=3306
# DB_USER=admin
# DB_PASSWORD=YOUR_AWS_RDS_PASSWORD
# DB_NAME=school

# API port (default in code is 3001 if unset).
PORT=3001

# Optional: extra CORS origins (comma-separated), merged with the built-in allowlist in src/app.ts
# (https://myamu.wanpanel.ai + local Vite hosts). Use for preview domains, staging, etc.
# Example: CORS_ORIGINS=https://your-preview.vercel.app
# CORS_ORIGINS=
# CORS_ORIGIN=

# --- Cloudflare Tunnel / API hostname reachability ---
# HTTP 530 with body "error code: 1033" means Cloudflare cannot reach the tunnel/origin (e.g.
# cloudflared not running, bad ingress/DNS, or origin down). Requests never hit Express, so
# changing CORS in this repo cannot fix that — repair the tunnel or hosting first.
#
# When the origin is reachable, verify (expect 200 JSON for health; OPTIONS should be 204 with CORS headers):
#   curl -sS -i 'https://myamu-api.wanpanel.ai/api/health'
#   curl -sS -i -X OPTIONS 'https://myamu-api.wanpanel.ai/api/admin/students?page=1&pageSize=25' \
#     -H 'Origin: https://myamu.wanpanel.ai' \
#     -H 'Access-Control-Request-Method: GET'

# Create portal billing tables + dev seed (AMU123456): npm run db:bootstrap-portal

# Legacy Mongo seed only (`npm run seed` under backend/legacy)
# MONGODB_URI=mongodb://127.0.0.1:27017/student-tuition-portal

# OpenAI (optional — `npm run test:openai`, `npm run build:knowledge`)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-thinking
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Student AI auth token signing secret.
# Required in production for authenticated student AI requests.
# STUDENT_AUTH_SECRET=replace-with-a-long-random-secret

# Optional student auth token lifetime in seconds (default: 43200 = 12 hours).
# STUDENT_AUTH_TOKEN_TTL_SECONDS=43200

# Authorize.net (Accept.js opaqueData charge endpoint)
# AUTHORIZE_API_LOGIN_ID=
# AUTHORIZE_TRANSACTION_KEY=
# AUTHORIZE_ENV=sandbox

# Supabase Storage (student profile photo upload/sign URL via backend only)
# Keep bucket private in Supabase dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=student-photos
