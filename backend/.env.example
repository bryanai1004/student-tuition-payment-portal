# API port (default in code is 3001 if unset).
PORT=3001

# Optional: extra CORS origins (comma-separated), merged with the built-in allowlist in src/app.ts
# (https://myamu.wanpanel.ai + local Vite hosts). Use for preview domains, staging, etc.
# Example: CORS_ORIGINS=https://your-branch.student-tuition-payment-portal.pages.dev
# CORS_ORIGINS=
# CORS_ORIGIN=

# Supabase (PostgreSQL database + Auth + Storage)
# Project: https://supabase.com/dashboard/project/okeiftbrwhfehflpxogs
# Schemas: https://supabase.com/dashboard/project/okeiftbrwhfehflpxogs/database/schemas
SUPABASE_URL=https://okeiftbrwhfehflpxogs.supabase.co
# Secret key from Dashboard → Project Settings → API Keys → Secret key (sb_secret_…)
SUPABASE_SERVICE_ROLE_KEY=
# Publishable key from Dashboard → API Keys (sb_publishable_… or legacy anon JWT)
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=student-photos

# Direct Postgres (Session pooler, port 5432) — NOT the same as SUPABASE_SERVICE_ROLE_KEY.
# Password: Dashboard → Project Settings → Database → Database password
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.okeiftbrwhfehflpxogs
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_NAME=postgres
# DB_SSL=1

# --- Cloudflare Workers (production API on myamu-api.wanpanel.ai) ---
# Deploy with Wrangler + Hyperdrive → Supabase Postgres (Session pooler).
# 1. Create Hyperdrive:
#      npx wrangler hyperdrive create myamu-supabase \
#        --connection-string="postgresql://postgres.okeiftbrwhfehflpxogs:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres" \
#        --sslmode=require
# 2. Paste Hyperdrive id into backend/wrangler.toml (current: f9cdb09006c045dd9de2b43f724278fb)
# 3. Set secrets: npx wrangler secret put STUDENT_AUTH_SECRET  (etc.)
# 4. Deploy: npm run deploy -w backend
# Local worker dev: copy backend/.dev.vars.example → backend/.dev.vars, then npm run dev:worker -w backend
# USE_HYPERDRIVE=1

# Portal billing tables + dev seed (AMU123456): npm run db:bootstrap-portal

# Legacy Mongo seed only (`npm run seed` under backend/legacy)
# MONGODB_URI=mongodb://127.0.0.1:27017/myamu

# OpenAI (optional — `npm run test:openai`, `npm run build:knowledge`)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-thinking
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Student AI auth token signing secret.
# Required in production for authenticated student AI requests.
# STUDENT_AUTH_SECRET=replace-with-a-long-random-secret

# SendGrid SMTP (OTP, password reset, admin bulk email)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key
# SMTP_FROM_ADDRESS=myamu-noreply@wanpanel.ai
# SMTP_FROM_NAME=Alhambra Medical University

# Optional student auth token lifetime in seconds (default: 43200 = 12 hours).
# STUDENT_AUTH_TOKEN_TTL_SECONDS=43200

# Authorize.net (Accept.js opaqueData charge endpoint)
# AUTHORIZE_API_LOGIN_ID=
# AUTHORIZE_TRANSACTION_KEY=
# AUTHORIZE_ENV=sandbox
