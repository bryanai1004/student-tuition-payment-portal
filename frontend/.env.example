# Backend base URL (no trailing slash). Required for production when the frontend is not served
# from the same origin as the API (e.g. Vercel app + API on Render/Railway).
#
# Local: this repo includes `.env.development` with `VITE_API_BASE_URL=http://127.0.0.1:3001`
# so `npm run dev` talks to the local API. Override with `.env.development.local` (gitignored)
# if needed. Production builds do not load `.env.development` — set `VITE_API_BASE_URL` in
# the Vercel project (or `.env.production.local` on your machine for `vite build` tests).
#
# If you omit `VITE_API_BASE_URL` everywhere for dev, Vite proxies `/api` to the backend instead.
#
# Production / preview (hosting dashboard or .env.production.local):
#   VITE_API_BASE_URL=https://your-api.example.com
VITE_API_BASE_URL=
