# Backend base URL (NO trailing slash, NO /api)

# Local example:

# VITE_API_BASE_URL=http://127.0.0.1:3001

# Production example:

# VITE_API_BASE_URL=https://myamu-api.wanpanel.ai

VITE_API_BASE_URL=

# Authorize.net Accept.js (public client-side identifiers)
VITE_AUTHORIZE_API_LOGIN_ID=
VITE_AUTHORIZE_CLIENT_KEY=

# Apple Pay on the Web (Safari / iPhone). Requires Apple Developer merchant ID,
# domain verification file at /.well-known/apple-developer-merchantid-domain-association,
# and matching backend secrets (APPLE_PAY_*).
# VITE_APPLE_PAY_MERCHANT_ID=merchant.com.example.myamu
# VITE_APPLE_PAY_DISPLAY_NAME=Alhambra Medical University
# VITE_APPLE_PAY_ENABLED=true

# AMU AI Assistant — set to false to enable live chat (default: coming soon)
# VITE_AI_ASSISTANT_COMING_SOON=false
