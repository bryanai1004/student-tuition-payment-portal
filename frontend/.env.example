# Backend base URL (NO trailing slash, NO /api)

# Local example:

# Local dev: leave empty — Vite proxies /api to the backend (see frontend/vite.config.ts).
# Do NOT point at http://127.0.0.1:3001 while using http://localhost:5175 — admin cookies break → 401.
# VITE_API_BASE_URL=

# Production example:

# VITE_API_BASE_URL=https://myamu-api.wanpanel.ai

VITE_API_BASE_URL=

# Supabase Realtime (admin enrollment change notifications in production)
# Project URL is public; anon/publishable key is safe in the browser bundle.
# VITE_SUPABASE_URL=https://okeiftbrwhfehflpxogs.supabase.co
# VITE_SUPABASE_ANON_KEY=

# Authorize.net Accept.js (public client-side identifiers)
VITE_AUTHORIZE_API_LOGIN_ID=
VITE_AUTHORIZE_CLIENT_KEY=

# AMU AI Assistant — set to false to enable live chat (default: coming soon)
# VITE_AI_ASSISTANT_COMING_SOON=false
